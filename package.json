{
  "name": "activity-score-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "dev:server": "npm run dev --workspace server",
    "build:web": "npm run build --workspace web",
    "build:server": "npm run build --workspace server",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "start:server": "npm run start --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:dbpush": "npm run prisma:dbpush --workspace server",
    "seed": "npm run seed --workspace server",
    "deploy:prod": "bash ./deploy.sh"
  }
}
